DATABASE_URL=postgresql://user:pass@localhost:5432/gwpm
REDIS_URL=redis://localhost:6379

# ── AI 模型配置 ──────────────────────────────
# 全局默认模型（可选值见下方别名列表）
DEFAULT_AI_MODEL=glm-4

# 各 Agent 专属模型（不填则用 DEFAULT_AI_MODEL）
# ZHONGSHU_MODEL=glm-4
# MENXIA_MODEL=glm-4-flash
# LIBU_LI2_MODEL=glm-4-flash

# 请求超时（毫秒）
AI_REQUEST_TIMEOUT_MS=45000

# ── 各 Provider API Key ──────────────────────
ANTHROPIC_API_KEY=           # Claude
ZHIPU_API_KEY=               # 智谱 GLM（open.bigmodel.cn 注册获取）
ARK_API_KEY=                 # 火山方舟 / 豆包
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_FAST=doubao-seed-1-6-flash-250828
DOUBAO_MODEL=doubao-seed-1-6-251015
MINIMAX_API_KEY=             # MiniMax
MINIMAX_API_BASE=https://api.minimaxi.com/v1
DEEPSEEK_API_KEY=            # DeepSeek

# ── 可用模型别名速查 ─────────────────────────
# claude         → Claude claude-sonnet-4-6（Anthropic）
# glm-flash      → GLM-4-Flash（智谱，最便宜）
# glm-air        → GLM-4-Air（智谱，均衡）
# glm            → GLM-4（智谱，标准）
# glm-5          → GLM-5（智谱，最强）
# doubao-fast    → 豆包 Seed 1.6 Flash（火山方舟）
# doubao         → 豆包 Seed 1.6（火山方舟）
# deepseek       → DeepSeek-Chat
# deepseek-r1    → DeepSeek-Reasoner
# minimax-fast   → MiniMax-M2.1（响应快）
# minimax        → MiniMax-M2.5（质量高）

GITHUB_TOKEN=ghp_...
WECOM_MODE=bot
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_AGENT_SECRET=
WECOM_BOT_TOKEN=
WECOM_BOT_AESKEY=
WECOM_BOT_ID=
WECOM_BOT_SECRET=
# 腾讯智能表格改为项目级 Webhook 配置，无需全局 App ID / App Secret
GWPM_JWT_SECRET=
